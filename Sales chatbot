<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AVA - Neurofive Solutions</title>
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Arial, sans-serif; }
  body { background: #0a0a0a; color: #fff; display: flex; justify-content: center; align-items: center; height: 100vh; }
  .chat-container { width: 480px; height: 720px; background: #111; border: 1px solid #2a2a2a; border-radius: 16px; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 0 30px rgba(0,114,255,0.2); }
  .chat-header { background: linear-gradient(90deg, #00c6ff, #0072ff); padding: 20px; text-align: center; font-size: 18px; font-weight: 700; letter-spacing: 0.5px; }
  .chat-sub { font-size: 12px; font-weight: 400; opacity: 0.9; }
  .chat-box { flex: 1; padding: 18px; overflow-y: auto; background: #0a0a0a; }
  .chat-box::-webkit-scrollbar { width: 6px; }
  .chat-box::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
  .message { margin-bottom: 14px; padding: 12px 16px; border-radius: 18px; max-width: 85%; line-height: 1.5; font-size: 14px; animation: fadeIn 0.3s; }
  @keyframes fadeIn { from {opacity: 0; transform: translateY(5px);} to {opacity: 1; transform: translateY(0);} }
  .user { background: #0072ff; margin-left: auto; border-bottom-right-radius: 4px; }
  .ava { background: #1e1e1e; margin-right: auto; border-bottom-left-radius: 4px; }
  .typing { font-style: italic; opacity: 0.7; }
  .chat-input { display: flex; padding: 14px; border-top: 1px solid #2a2a2a; background: #111; }
  .chat-input input { flex: 1; padding: 12px 14px; border: none; border-radius: 10px; background: #1e1e1e; color: #fff; outline: none; font-size: 14px; }
  .chat-input button { margin-left: 8px; padding: 12px 18px; background: #0072ff; border: none; border-radius: 10px; color: #fff; cursor: pointer; font-weight: 600; transition: 0.2s; }
  .chat-input button:hover { background: #005bb5; }
  .chat-input button:disabled { background: #333; cursor: not-allowed; }
</style>
</head>
<body>

<div class="chat-container">
  <div class="chat-header">
    AVA
    <div class="chat-sub">Neurofive Solutions Sales Assistant</div>
  </div>
  <div class="chat-box" id="chatBox">
    <div class="message ava">Hi! I'm AVA 👋 I'm here to help with Neurofive App, Store, and Cloud. How can I help you today?</div>
  </div>
  <div class="chat-input">
    <input type="text" id="userInput" placeholder="Ask about Neurofive products..." />
    <button id="sendBtn" onclick="sendMessage()">Send</button>
  </div>
</div>

<script>
const chatBox = document.getElementById("chatBox");
const userInput = document.getElementById("userInput");
const sendBtn = document.getElementById("sendBtn");

let history = []; // keeps conversation context for the backend

function addMessage(text, sender) {
  const div = document.createElement("div");
  div.className = `message ${sender}`;
  div.innerHTML = text;
  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

async function sendMessage() {
  const message = userInput.value.trim();
  if (!message) return;

  addMessage(message, "user");
  history.push({role: "user", content: message});
  userInput.value = "";
  sendBtn.disabled = true;

  // Show typing indicator
  addMessage("AVA is typing...", "ava typing");
  
  try {
    const response = await fetch("/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ message: message, history: history })
    });

    const data = await response.json();
    
    // Remove typing indicator
    document.querySelector(".typing")?.remove();

    const reply = data.reply;
    addMessage(reply, "ava");
    history.push({role: "assistant", content: reply});

  } catch (error) {
    document.querySelector(".typing")?.remove();
    addMessage("Sorry, I'm having trouble connecting. Please try again.", "ava");
  }
  sendBtn.disabled = false;
  userInput.focus();
}

// Send on Enter key
userInput.addEventListener("keypress", function(e) {
  if (e.key === "Enter") sendMessage();
});
</script>

</body>
</html>
